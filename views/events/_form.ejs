<% // Helper to check errors const hasError=(field)=> error && error.includes(field);
    // Simple error checking based on flash string isn't granular.
    // We passed 'event' object. If we had validation errors attached to it, we could use them.
    // Since we don't have detailed validation errors from Sequelize mapped back easily without extra work,
    // we'll rely on global error flash for now or basic styling.

    // Actually in controller catch block: res.render('events/new', { event: req.body, error: error.message });
    // So 'event' has the body.
    %>

    <form action="<%= action %>" method="POST" class="space-y-6">
        <!-- Method Override for PUT if editing -->
        <% if (method==='PUT' ) { %>
            <input type="hidden" name="_method" value="PUT">
            <% } %>

                <% if (typeof error !=='undefined' && error) { %>
                    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl">
                        <div class="flex items-center mb-2">
                            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd"
                                    d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"
                                    clip-rule="evenodd" />
                            </svg>
                            <span class="font-medium">Error saving event:</span>
                        </div>
                        <ul class="list-disc list-inside text-sm space-y-1">
                            <li>
                                <%= error %>
                            </li>
                        </ul>
                    </div>
                    <% } %>

                        <div>
                            <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                            <input type="text" name="title" id="title" value="<%= event.title || '' %>"
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 transition-all outline-none"
                                placeholder="e.g., Community Iftar at the Park" required>
                            <p class="mt-1 text-sm text-gray-500">Give your event a descriptive title</p>
                        </div>

                        <div>
                            <label for="description"
                                class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                            <textarea name="description" id="description" rows="4"
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 transition-all outline-none"
                                placeholder="Tell guests what to expect, what to bring, dietary options, etc."><%= event.description || '' %></textarea>
                        </div>

                        <div class="grid md:grid-cols-2 gap-6">
                            <div>
                                <label for="date" class="block text-sm font-medium text-gray-700 mb-1">Date &
                                    Time</label>
                                <% // Format date for datetime-local input: YYYY-MM-DDTHH:mm let dateValue='' ; if
                                    (event.date) { const d=new Date(event.date); d.setMinutes(d.getMinutes() -
                                    d.getTimezoneOffset()); // local time hack dateValue=d.toISOString().slice(0, 16); }
                                    %>
                                    <input type="datetime-local" name="date" id="date" value="<%= dateValue %>"
                                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 transition-all outline-none"
                                        required>
                                    <p class="mt-1 text-sm text-gray-500">When will the Iftar take place?</p>
                            </div>

                            <div>
                                <label for="capacity"
                                    class="block text-sm font-medium text-gray-700 mb-1">Capacity</label>
                                <input type="number" name="capacity" id="capacity" min="1"
                                    value="<%= event.capacity || '' %>"
                                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 transition-all outline-none"
                                    placeholder="e.g., 20">
                                <p class="mt-1 text-sm text-gray-500">Maximum number of guests (leave blank for
                                    unlimited)</p>
                            </div>
                        </div>

                        <div>
                            <label for="location" class="block text-sm font-medium text-gray-700 mb-1">Location</label>
                            <input type="text" name="location" id="location" value="<%= event.location || '' %>"
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 transition-all outline-none"
                                placeholder="e.g., 123 Main Street, Community Center" required>
                            <p class="mt-1 text-sm text-gray-500">Where will guests meet?</p>
                        </div>

                        <div>
                            <label for="rsvp_closes_before" class="block text-sm font-medium text-gray-700 mb-1">RSVP
                                Deadline</label>
                            <select name="rsvp_closes_before" id="rsvp_closes_before"
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 transition-all outline-none bg-white">
                                <% const options={ "No limit" : "" , "1 hour before" : 1, "3 hours before" :
                                    3, "6 hours before" : 6, "12 hours before" : 12, "24 hours before" : 24 }; %>
                                    <% for (const [label, value] of Object.entries(options)) { %>
                                        <option value="<%= value %>" <%=event.rsvp_closes_before==value ? 'selected'
                                            : '' %>><%= label %>
                                        </option>
                                        <% } %>
                            </select>
                            <p class="mt-1 text-sm text-gray-500">When should RSVPs close before the event?</p>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-3">Event Banner</label>
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                                <% ['banner-1.jpg', 'banner-2.jpg' , 'banner-3.jpg' ].forEach((banner, index)=> { %>
                                    <label class="relative cursor-pointer group">
                                        <input type="radio" name="banner_image" value="<%= banner %>"
                                            class="peer sr-only" <%=(event.banner_image===banner || (!event.banner_image
                                            && index===0)) ? 'checked' : '' %>>
                                        <div
                                            class="rounded-xl overflow-hidden border-4 border-transparent peer-checked:border-amber-500 peer-checked:shadow-lg transition-all relative">
                                            <img src="/<%= banner %>"
                                                class="w-full h-32 object-cover group-hover:scale-105 transition-transform duration-300">
                                            <div
                                                class="absolute inset-0 bg-black/40 opacity-0 peer-checked:opacity-100 flex items-center justify-center transition-opacity">
                                                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="3" d="M5 13l4 4L19 7" />
                                                </svg>
                                            </div>
                                        </div>
                                    </label>
                                    <% }); %>
                            </div>
                            <p class="mt-2 text-sm text-gray-500">Choose a cover image for your event page</p>
                        </div>

                        <div class="pt-4">
                            <button type="submit"
                                class="w-full sm:w-auto px-8 py-3 bg-gradient-to-r from-amber-500 to-orange-500 text-white rounded-xl font-semibold hover:from-amber-600 hover:to-orange-600 transition-all shadow-lg hover:shadow-xl cursor-pointer">
                                <%= submitText %>
                            </button>
                        </div>
    </form>